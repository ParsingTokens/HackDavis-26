# PostGIS Database
DATABASE_URL=postgresql+asyncpg://thermal:thermal_secret@localhost:5432/thermal_routing

# Davis, CA Coordinates
DAVIS_LAT=38.5449
DAVIS_LON=-121.7405

# Default Heat Index (°F) — used when not provided as a query parameter
DEFAULT_HEAT_INDEX=90.0

# OpenWeatherMap API Key (optional, for live heat index)
# OPENWEATHER_API_KEY=your_key_here
